---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

const tabs = [
  { label: "Inicio", href: base, icon: "home" },
  { label: "Núcleo", href: `${base}nucleo-academico`, icon: "users" },
  { label: "Ejes", href: `${base}ejes-formativos`, icon: "book" },
  { label: "Tesinas", href: `${base}repositorio-tesinas`, icon: "file" },
];

function isActive(href: string) {
  if (href === base) return currentPath === base || currentPath === `${base}/` || currentPath === "/";
  return currentPath.startsWith(href);
}
---

<nav
  class="md:hidden fixed bottom-0 inset-x-0 z-50 bg-card/95 backdrop-blur-md border-t border-border pb-[env(safe-area-inset-bottom)] shadow-[0_-2px_12px_rgba(0,0,0,0.06)]"
  aria-label="Navegación principal"
>
  <ul class="grid grid-cols-4">
    {tabs.map((tab) => {
      const active = isActive(tab.href);
      return (
        <li>
          <a
            href={tab.href}
            class:list={[
              "relative flex flex-col items-center justify-center gap-0.5 py-2.5 text-[11px] font-medium transition-colors",
              active ? "text-red-700" : "text-muted-foreground hover:text-foreground",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {tab.icon === "home" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 9.5 12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-7h-6v7H4a1 1 0 0 1-1-1z" />
              </svg>
            )}
            {tab.icon === "users" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
              </svg>
            )}
            {tab.icon === "book" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
              </svg>
            )}
            {tab.icon === "file" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <path d="M14 2v6h6" />
                <path d="M9 13h6" />
                <path d="M9 17h6" />
              </svg>
            )}
            <span>{tab.label}</span>
            {active && (
              <span class="absolute top-0 h-0.5 w-10 bg-red-700 rounded-full" aria-hidden="true"></span>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
