---
import BaseLayout from "@/layouts/BaseLayout.astro";
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
---

<BaseLayout title="Preparatoria Popular Gral. Emiliano Zapata | 404" description="Página no encontrada" noFooter={true}>
  <section class="flex min-h-screen items-center justify-center bg-muted px-4">
    <div class="text-center">
      <h1 class="mb-4 text-4xl font-bold">404</h1>
      <p class="mb-4 text-xl text-muted-foreground">Página no encontrada</p>
      <a href={base} class="text-primary underline hover:text-primary/90">Regresar al inicio</a>
    </div>
  </section>
</BaseLayout>
