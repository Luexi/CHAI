---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { PageHeader } from "@/components/ui/PageHeader";
import { EjeFormativoCard } from "@/components/cards/EjeFormativoCard";
import { ejesFormativos } from "@/data/ejesFormativos";
import { institucion } from "@/data/site";
---

<BaseLayout
  title={`Ejes Formativos | ${institucion.nombre}`}
  description="Conoce los ejes formativos de Humanidades y Pensamiento Matemático, pilares para el desarrollo crítico, ético, lógico y creativo de los estudiantes."
>
  <PageHeader
    title="Ejes Formativos"
    subtitle="Humanidades y Pensamiento Matemático como bases para el desarrollo crítico, ético, lógico y creativo de los estudiantes."
    badge="Formación Integral"
  />

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <p class="text-center text-lg leading-relaxed text-muted-foreground">
        Estos ejes fortalecen la formación integral del estudiante al vincular la sensibilidad humana, la reflexión ética y el razonamiento lógico con situaciones de la vida académica y social.
      </p>
    </div>
  </section>

  <section class="pb-16">
    <div class="max-w-6xl mx-auto px-4 space-y-10">
      {ejesFormativos.map((eje, index) => (
        <EjeFormativoCard eje={eje} reverse={index % 2 === 1} />
      ))}
    </div>
  </section>

  <section class="pb-16 md:pb-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="rounded-2xl bg-primary px-5 py-8 md:px-6 md:py-10 text-center text-primary-foreground shadow-sm">
        <p class="mx-auto max-w-3xl text-base md:text-lg leading-relaxed">
          Estos ejes fortalecen la formación integral del estudiante, combinando sensibilidad humana, pensamiento crítico y razonamiento lógico para comprender y transformar su entorno.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Rotar chevron cuando el details está abierto */
  details.eje-collapsible[open] > summary .eje-chevron {
    transform: rotate(180deg);
  }
  /* Quitar el triángulo nativo del summary */
  details.eje-collapsible > summary::-webkit-details-marker { display: none; }
  details.eje-collapsible > summary::marker { content: ""; }
</style>

<script>
  // En desktop (md+): forzar todos los <details data-mobile-collapsible> abiertos
  // y evitar que el click en summary los cierre. En mobile: comportamiento nativo.
  const mql = window.matchMedia("(min-width: 768px)");
  const collapsibles = () => document.querySelectorAll<HTMLDetailsElement>("details[data-mobile-collapsible]");

  function syncOpen() {
    if (mql.matches) {
      collapsibles().forEach((d) => { d.open = true; });
    }
  }

  syncOpen();
  mql.addEventListener("change", syncOpen);

  document.addEventListener("click", (e) => {
    if (!mql.matches) return;
    const target = e.target as HTMLElement;
    const summary = target.closest("details[data-mobile-collapsible] > summary");
    if (summary) e.preventDefault();
  });
</script>
