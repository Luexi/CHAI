---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { PageHeader } from "@/components/ui/PageHeader";
import { DocenteCard } from "@/components/cards/DocenteCard";
import { docentes, directorGeneral, coordinadorEscolar } from "@/data/docentes";
import { institucion } from "@/data/site";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;

// Orden alfabético por nombre, pero los slots pendientes quedan al final.
const docentesOrdenados = [...docentes].sort((a, b) => {
  if (a.pendiente && !b.pendiente) return 1;
  if (!a.pendiente && b.pendiente) return -1;
  return a.nombre.localeCompare(b.nombre, "es");
});

const directores = [directorGeneral, coordinadorEscolar];
---

<BaseLayout
  title={`${institucion.nombreCorto} | Núcleo Académico`}
  description="Conoce al cuerpo docente de la Preparatoria Popular General Emiliano Zapata."
>
  <PageHeader
    title="Núcleo Académico"
    subtitle="Conoce a los docentes que conforman nuestra preparatoria"
    badge="Cuerpo Docente"
  />

  <!-- Directores destacados -->
  <section class="pt-8 pb-8 md:pt-16 md:pb-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 place-items-center">
        {directores.map((director) => (
          <div class="flex flex-col items-center text-center w-full">
            <div class="relative w-56 sm:w-64 md:w-[22rem] lg:w-[24rem] aspect-square">
              <!-- Capa decorativa offset (siempre visible, más sutil en mobile) -->
              <div class="absolute -inset-2 md:-inset-3 -z-10 rounded-sm bg-gradient-to-br from-red-700 via-red-700/70 to-blue-900 opacity-70 md:opacity-100"></div>
              <img
                src={`${base}${director.foto}`}
                alt={director.nombre}
                loading="lazy"
                class="relative w-full h-full object-cover rounded-sm shadow-xl md:shadow-2xl ring-1 ring-black/10"
              />
              <!-- Corner brackets y cinta solo en desktop -->
              <span class="hidden md:block absolute -top-2 -left-2 h-10 w-10 border-t-4 border-l-4 border-red-700 pointer-events-none"></span>
              <span class="hidden md:block absolute -bottom-2 -right-2 h-10 w-10 border-b-4 border-r-4 border-blue-900 pointer-events-none"></span>
              <span class="hidden md:block absolute -bottom-3 left-6 h-1 w-24 bg-red-700"></span>
            </div>
            <span class="mt-5 md:mt-8 inline-block px-2.5 py-0.5 md:px-3 md:py-1 bg-red-700/10 text-red-700 text-xs md:text-sm font-medium rounded-full uppercase tracking-wide">
              {director.cargo}
            </span>
            <h2 class="mt-2 md:mt-3 font-display text-xl sm:text-2xl md:text-3xl font-bold text-foreground leading-tight">
              {director.nombre}
            </h2>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cuerpo docente -->
  <section class="py-8 md:py-10">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-6">
        {docentesOrdenados.map((docente) => <DocenteCard docente={docente} />)}
      </div>
    </div>
  </section>
</BaseLayout>
