---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { PageHeader } from "@/components/ui/PageHeader";
import { TesisCard } from "@/components/cards/TesisCard";
import { tesis } from "@/data/tesis";
import { institucion } from "@/data/site";
---

<BaseLayout
  title={`${institucion.nombreCorto} | Repositorio de Tesis`}
  description="Consulta los proyectos de tesis de la Preparatoria Popular General Emiliano Zapata."
>
  <PageHeader
    title="Repositorio de Tesis"
    subtitle="Proyectos de tesis presentados por nuestros estudiantes"
    badge="Trabajos de Grado"
  />

  <!-- TODO: Reemplazar las 3 tesis placeholder con datos reales a finales de marzo 2026.
       Editar en: src/data/tesis.ts -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid gap-6">
        {tesis.map((item) => <TesisCard tesis={item} />)}
      </div>
    </div>
  </section>
</BaseLayout>
